{
  "schema_version": 1,
  "package_name": "sentinelayer-cli",
  "quality": {
    "workflow_path": ".github/workflows/quality-gates.yml",
    "package_artifact_name": "quality-package-artifacts",
    "summary_manifest_artifact_name": "quality-summary-manifest",
    "required_manifest_fields": [
      "tarball",
      "sha256",
      "lockfile_sha256",
      "workflow_path",
      "workflow_sha256",
      "commit_sha",
      "workflow_ref",
      "run_id",
      "release_provenance_policy_sha256"
    ]
  },
  "attestation": {
    "workflow_path": ".github/workflows/attestations.yml",
    "build_artifact_name": "attestation-build-artifacts",
    "required_manifest_fields": [
      "tarball",
      "sha256",
      "workflow_name",
      "workflow_ref",
      "workflow_path",
      "workflow_sha256",
      "run_id",
      "commit_sha",
      "release_provenance_policy_sha256"
    ]
  },
  "release": {
    "workflow_path": ".github/workflows/release.yml",
    "artifact_name": "release-artifact",
    "trusted_ref_pattern": "refs/tags/v*",
    "required_manifest_fields": [
      "tarball",
      "sha256",
      "integrity",
      "source_workflow_name",
      "source_workflow_ref",
      "source_workflow_path",
      "source_run_id",
      "source_commit_sha",
      "release_workflow_sha256",
      "release_provenance_policy_sha256"
    ]
  }
}
